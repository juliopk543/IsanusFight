             Baby (3 e 4 anos)
            </option>
            <option>
             Mirim (5 a 8 anos)
            </option>
            <option>
             Infantil
            </option>
            <option>
             Juvenil
            </option>
            <option>
             Aula Coletiva (adulto)
            </option>
            <option>
             Aula Individual
            </option>
            <option>
