           </div>
           <div>
            <label class="block text-sm font-bold text-zinc-700 uppercase tracking-wider mb-2" for="idade">
             Idade
            </label>
            <input class="w-full px-5 py-4 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-red-600 focus:border-transparent outline-none transition-all" id="idade" placeholder="Sua idade" required type="number" value>
           </div>
          </div>
          <div>
           <label class="block text-sm font-bold text-zinc-700 uppercase tracking-wider mb-2" for="modalidade">
            Modalidade de Interesse
           </label>
           <select class="w-full px-5 py-4 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-red-600 focus:border-transparent outline-none transition-all appearance-none" id="modalidade">
